rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function myEmployeeId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employeeId;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && getRole() == "admin";
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null && (
        getRole() == "admin" || myEmployeeId() == employeeId
      );
      allow write: if request.auth != null && getRole() == "admin";
      // Employees CANNOT write directly, even to their own doc — bank detail
      // change requests go through a server action (see
      // /api/employees/bank-change-request) that writes to
      // bankAccountPending only, never directly to bankAccount.
    }

    match /taxSettings/{versionId} {
      allow read: if request.auth != null && getRole() == "admin";
      allow create: if request.auth != null && getRole() == "admin";
      allow update, delete: if false; // versions are immutable once created
    }

    // Declared at top level with a recursive wildcard rather than nested
    // inside /payrollRuns/{runId} — this is what makes it apply cleanly to
    // the collectionGroup("payslips") query "My Payslips" uses.
    match /{path=**}/payslips/{employeeId} {
      // The "this is my own payslip" branch uses request.auth.token.employeeId
      // (a Firebase Auth custom claim baked into the login token) instead of
      // myEmployeeId() (a Firestore get() lookup). Firestore cannot reliably
      // prove a get()-derived comparison is safe for a collectionGroup LIST
      // query — even split into its own `allow read` statement — so it gets
      // rejected as "Missing or insufficient permissions" even when the
      // data and rule text are both correct. Custom claims avoid the get()
      // entirely, which Firestore can always structurally verify.
      allow read: if request.auth != null && resource.data.employeeId == request.auth.token.employeeId;
      allow read: if request.auth != null && getRole() == "admin";
      allow write: if request.auth != null && getRole() == "admin";
    }

    match /settings/{docId} {
      allow read: if request.auth != null && getRole() == "admin";
      allow write: if request.auth != null && getRole() == "admin";
    }

    match /payrollRuns/{runId} {
      allow read: if request.auth != null && getRole() == "admin";
      allow write: if request.auth != null && getRole() == "admin";
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }
  }
}
